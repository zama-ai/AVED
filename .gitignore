# Object and build artifacts
# Ignore compiled object files, static libraries, and build-related files generated during compilation.
*.o
*.a
*.swp
*.swo
*.elf
*.d
*.cmd

# Non-public and temporary output
# Ignore output directories used for Perforce or other non-public/temporary files.
output/

# Editor and IDE settings
# Ignore VS Code configuration files and directories.
.vscode/

# Deployment directory (under review)
# Commented out pending discussion on whether to include the deploy folder.
#deploy/

# Python cache
# Ignore Python bytecode cache directories generated by Python scripts.
__pycache__/

# Software packages
# Ignore Debian, RPM, and ZIP package files generated during packaging.
*.deb
*.rpm
*.zip

# AMD Vitis/Xilinx build artifacts
# Ignore temporary files and directories created by Vitis during FPGA development.
.Xil

# Test-related files and directories
# Ignore test frameworks, test sources, and build artifacts for unit/component tests.
CMocka/
componentTest/
**/AMC/src/test/
**/AMI/test/
**/AMI/api/build/

# Board Support Package (BSP) and IDE metadata
# Ignore generated BSP directories, IDE metadata, analytics, and log files.
amc_bsp/
.metadata/
.analytics
IDE.log

# Miscellaneous
# Ignore NFS-related temporary files created during network file operations.
.nfs*
